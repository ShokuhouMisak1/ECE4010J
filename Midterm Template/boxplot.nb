 RowBox[{
  RowBox[{
   RowBox[{"innerFences", "=", 
    RowBox[{"{", 
     RowBox[{"innerLowerFence", ",", "innerUpperFence"}], "}"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Calculate", " ", "Outer", " ", "Fences"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"outerLowerFence", "=", 
   RowBox[{"q1", "-", 
    RowBox[{"3", "*", "iqr"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"outerUpperFence", "=", 
   RowBox[{"q3", "+", 
    RowBox[{"3", "*", "iqr"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"outerFences", "=", 
    RowBox[{"{", 
     RowBox[{"outerLowerFence", ",", "outerUpperFence"}], "}"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Determine", " ", "Actual", " ", "Whisker", " ", "Ends", " ", 
    RowBox[{"(", 
     RowBox[{"values", " ", "within", " ", "inner", " ", "fences"}], ")"}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"actualWhiskerLower", "=", 
   RowBox[{"Max", "[", 
    RowBox[{"Select", "[", 
     RowBox[{"sortedData", ",", 
      RowBox[{
       RowBox[{"#", ">=", "innerLowerFence"}], "&"}]}], "]"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"actualWhiskerUpper", "=", 
   RowBox[{"Min", "[", 
    RowBox[{"Select", "[", 
     RowBox[{"sortedData", ",", 
      RowBox[{
       RowBox[{"#", "<=", "innerUpperFence"}], "&"}]}], "]"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"actualWhiskerEnds", "=", 
    RowBox[{"{", 
     RowBox[{"actualWhiskerLower", ",", "actualWhiskerUpper"}], "}"}]}], 
   ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Identify", " ", "Near", " ", "Outliers", " ", 
    RowBox[{"(", 
     RowBox[{
     "between", " ", "inner", " ", "and", " ", "outer", " ", "fences"}], 
     ")"}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"nearOutliersLower", "=", 
   RowBox[{"Select", "[", 
    RowBox[{"sortedData", ",", 
     RowBox[{
      RowBox[{"innerLowerFence", ">", "#", ">=", "outerLowerFence"}], "&"}]}],
     "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"nearOutliersUpper", "=", 
   RowBox[{"Select", "[", 
    RowBox[{"sortedData", ",", 
     RowBox[{
      RowBox[{"innerUpperFence", "<", "#", "<=", "outerUpperFence"}], "&"}]}],
     "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"nearOutliers", "=", 
    RowBox[{"Join", "[", 
     RowBox[{"nearOutliersLower", ",", "nearOutliersUpper"}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\n", 
  RowBox[{"(*", 
   RowBox[{"Identify", " ", "Far", " ", "Outliers", " ", 
    RowBox[{"(", 
     RowBox[{"beyond", " ", "outer", " ", "fences"}], ")"}]}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"farOutliersLower", "=", 
   RowBox[{"Select", "[", 
    RowBox[{"sortedData", ",", 
     RowBox[{
      RowBox[{"#", "<", "outerLowerFence"}], "&"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"farOutliersUpper", "=", 
   RowBox[{"Select", "[", 
    RowBox[{"sortedData", ",", 
     RowBox[{
      RowBox[{"#", ">", "outerUpperFence"}], "&"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
