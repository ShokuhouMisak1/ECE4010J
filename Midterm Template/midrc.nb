Cell[CellGroupData[{

Cell["\<\
Example: compute the two-sided 95% confidence interval for the mean\
\>", "Subsection",
 CellChangeTimes->{
  3.9202986960273604`*^9},ExpressionUUID->"74633fbf-901b-4ca8-bbde-\
59c6733e09ff"],

Cell["Direct Computation:", "Text",
 CellChangeTimes->{{3.9202987109587765`*^9, 
  3.9202987176257644`*^9}},ExpressionUUID->"e9e25b05-3cf9-480c-8e2c-\
3b663fc7b358"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"n", "=", 
   RowBox[{"Length", "[", "Data", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"\[Alpha]", "=", ".05"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"mean", "=", 
   RowBox[{"Mean", "[", "Data", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"s", "=", 
   RowBox[{"Sqrt", "[", " ", 
    RowBox[{"Variance", "[", "Data", "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"t", "=", 
   RowBox[{"InverseCDF", "[", 
    RowBox[{
     RowBox[{"StudentTDistribution", "[", 
      RowBox[{"n", "-", "1"}], "]"}], ",", 
     RowBox[{"1", "-", 
      RowBox[{"\[Alpha]", "/", "2"}]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"L", "=", 
   RowBox[{"t", "*", 
    RowBox[{"s", " ", "/", 
     SqrtBox["n"]}]}]}], ";"}], "\n", 
 RowBox[{"mean", "-", "L"}], "\n", 
 RowBox[{"mean", "+", "L"}]}], "Input",
 CellChangeTimes->{{3.9202987288993697`*^9, 3.920298902922717*^9}},
 CellLabel->"In[74]:=",ExpressionUUID->"0e686880-d3ab-47a0-ba4f-d8fa97e76817"],

Cell[BoxData["6.3948970738151605`"], "Output",
 CellChangeTimes->{{3.920298847790888*^9, 3.9202989034144173`*^9}},
 CellLabel->"Out[80]=",ExpressionUUID->"0f95d61a-f355-4316-82f0-9ae423417b38"],

Cell[BoxData["7.558044102655428`"], "Output",
 CellChangeTimes->{{3.920298847790888*^9, 3.9202989034213705`*^9}},
 CellLabel->"Out[81]=",ExpressionUUID->"af2a0d09-22c0-4cdc-829f-588ee7f718ba"]
}, Open  ]],

