Cell["\<\
For every distribution mentioned in the slide, Mathematica should have a \
corresponding Distribution. But be careful, distribution in Mathematica may \
be defined differently from the slide! (Especially when it  comes to gamma \
function \[CapitalGamma])\
\>", "Text",
 CellChangeTimes->{{3.920296450021309*^9, 3.9202965071929893`*^9}, {
  3.920296594349799*^9, 3.9202966719211802`*^9}, {3.9202967023449383`*^9, 
  3.9202967129888725`*^9}},ExpressionUUID->"72090023-bae7-47ce-ac20-\
c4a07d6f8503"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Transformation of  Variables", "Subsection",
 CellChangeTimes->{{3.920296797392371*^9, 
  3.920296814569333*^9}},ExpressionUUID->"7846b42a-67bb-408e-9652-\
37fc505ef108"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"X", "=", 
   RowBox[{"SomeDistribution", "[", "Parameters", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Y", "=", 
    RowBox[{"SomeDistribution", "[", "Parameters", "]"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Z", "=", 
   RowBox[{"TransformedDistribution", "[", 
    RowBox[{
     RowBox[{"Z", 
      RowBox[{"(", 
       RowBox[{"X", ",", "Y"}], ")"}]}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"x", "\[Distributed]", "X"}], ",", 
       RowBox[{"y", "\[Distributed]", "Y"}]}], "}"}]}], "]"}]}], 
  ";"}], "\n", "Z"}], "Code",
 CellChangeTimes->{{3.9202968530435333`*^9, 
  3.9202969190855293`*^9}},ExpressionUUID->"924d7364-da62-4595-99d4-\
b52cd2eac58f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"X", "=", 
   RowBox[{"NormalDistribution", "[", 
    RowBox[{"0", ",", "1"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Y", "=", 
    RowBox[{"NormalDistribution", "[", 
     RowBox[{"0", ",", "1"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Define", " ", "the", " ", "new", " ", "variable", " ", "Z"}], 
    "=", 
    RowBox[{
     RowBox[{"X", "^", "2"}], "+", 
     RowBox[{"Y", "^", "2"}]}]}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Z", "=", 
    RowBox[{"TransformedDistribution", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"x", "^", "2"}], "+", 
       RowBox[{"y", "^", "2"}]}], ",", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x", "\[Distributed]", "X"}], ",", 
        RowBox[{"y", "\[Distributed]", "Y"}]}], "}"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Display", " ", "the", " ", "distribution", " ", "of", " ", "Z"}], 
   "*)"}]}], "\n", "Z"}], "Input",
 CellLabel->"In[20]:=",ExpressionUUID->"4666b93b-9004-42c6-aaa7-3e528af9c0ea"],

Cell[BoxData[
 RowBox[{"ChiSquareDistribution", "[", "2", "]"}]], "Output",
 CellChangeTimes->{3.9202969439417677`*^9},
 CellLabel->"Out[23]=",ExpressionUUID->"5decddd9-7db1-45ec-b277-675652cb624f"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

