   3.920296379176731*^9},
 CellLabel->"In[15]:=",ExpressionUUID->"feef2823-c88d-4b89-9b97-dcdd073031e9"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "2"], " ", 
  RowBox[{"Erfc", "[", 
   FractionBox[
    RowBox[{
     RowBox[{"-", "x"}], "+", "\[Mu]"}], 
    RowBox[{
     SqrtBox["2"], " ", "\[Sigma]"}]], "]"}]}]], "Output",
 CellChangeTimes->{3.920296242876031*^9, 3.920296386553319*^9},
 CellLabel->"Out[15]=",ExpressionUUID->"2fafa964-495e-4bb9-894c-ff3770a5e29f"]
}, Open  ]],

