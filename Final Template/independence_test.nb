Notebook[{

Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"ClearAll", "[", 
    RowBox[{
    "SimpleChisquareIndependenceTest", ",", "scientificFormIfNeeded"}], "]"}],
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
    "Helper", " ", "function", " ", "for", " ", "printing", " ", "small", " ",
      "p"}], "-", "values"}], "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"scientificFormIfNeeded", "[", "p_", "]"}], ":=", 
    RowBox[{"If", "[", 
     RowBox[{
      RowBox[{"0", "<", "p", "<", "0.0001"}], ",", 
      RowBox[{"ScientificForm", "[", 
       RowBox[{"p", ",", "4"}], "]"}], ",", 
      RowBox[{"PaddedForm", "[", 
       RowBox[{"p", ",", 
        RowBox[{"{", 
         RowBox[{"8", ",", "6"}], "}"}]}], "]"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"SimpleChisquareIndependenceTest", "[", 
    RowBox[{"observedTable_", "?", "MatrixQ"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "r", ",", "c", ",", "n", ",", "rowSums", ",", "colSums", ",", 
       "observedTableWithMargins", ",", 
       RowBox[{"(*", 
        RowBox[{
        "New", " ", "variable", " ", "for", " ", "augmented", " ", "table"}], 
        "*)"}], "expectedNumTable", ",", "df", ",", "chiSquareStat", ",", 
       "pValue", ",", "criticalValue", ",", 
       RowBox[{"alpha", "=", "0.05"}]}], " ", 
      RowBox[{"(*", 
       RowBox[{
       "Fixed", " ", "significance", " ", "level", " ", "for", " ", 
        "conclusion"}], "*)"}], "}"}], ",", 
     RowBox[{"(*", 
      RowBox[{
      "1.", " ", "Calculate", " ", "Dimensions", " ", "and", " ", "Marginal", 
       " ", "Sums"}], "*)"}], 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"r", ",", "c"}], "}"}], "=", 
       RowBox[{"Dimensions", "[", "observedTable", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"rowSums", "=", 
       RowBox[{"Total", "[", 
        RowBox[{"observedTable", ",", 
         RowBox[{"{", "2", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"colSums", "=", 
       RowBox[{"Total", "[", 
        RowBox[{"observedTable", ",", 
         RowBox[{"{", "1", "}"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"n", "=", 
       RowBox[{"Total", "[", 
        RowBox[{"observedTable", ",", "2"}], "]"}]}], ";", 
      RowBox[{"(*", 
       RowBox[{"Or", " ", 
        RowBox[{"Total", "[", "rowSums", "]"}], " ", "or", " ", 
        RowBox[{"Total", "[", "colSums", "]"}]}], "*)"}], 
      RowBox[{"(*", 
       RowBox[{
       "Basic", " ", "check", " ", "for", " ", "valid", " ", "input", " ", 
        "total"}], "*)"}], 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"n", "==", "0"}], ",", 
        RowBox[{
         RowBox[{
         "Print", "[", "\"\<Error: Total observations is zero.\>\"", "]"}], 
         ";", 
         RowBox[{"Return", "[", "$Failed", "]"}]}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"1", 
        RowBox[{"b", ".", "Construct"}], " ", "Observed", " ", "Table", " ", 
        "with", " ", "Margins"}], "*)"}], 
      RowBox[{"(*", 
       RowBox[{
       "Add", " ", "column", " ", "sums", " ", "as", " ", "a", " ", "new", 
        " ", "row", " ", "at", " ", "the", " ", "bottom"}], "*)"}], 
      RowBox[{"observedTableWithMargins", "=", 
       RowBox[{"Join", "[", 
        RowBox[{"observedTable", ",", 
         RowBox[{"{", "colSums", "}"}], ",", "1"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Add", " ", "row", " ", "sums", " ", 
        RowBox[{"(", 
         RowBox[{"and", " ", "grand", " ", "total", " ", "n"}], ")"}], " ", 
        "as", " ", "a", " ", "new", " ", "column", " ", "at", " ", "the", " ",
         "right"}], "*)"}], 
      RowBox[{"observedTableWithMargins", "=", 
       RowBox[{"Join", "[", 
        RowBox[{"observedTableWithMargins", ",", 
         RowBox[{"List", "/@", 
          RowBox[{"Append", "[", 
           RowBox[{"rowSums", ",", "n"}], "]"}]}], ",", "2"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"2.", " ", "Calculate", " ", "Expected", " ", "Frequencies"}], 
       "*)"}], 
      RowBox[{"(*", 
       RowBox[{"Eij", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"ni", "."}], " ", "*", 
           RowBox[{"n", ".", "j"}]}], ")"}], "/", "n"}]}], "*)"}], 
      RowBox[{"expectedNumTable", "=", 
       RowBox[{
        RowBox[{"Outer", "[", 
         RowBox[{"Times", ",", "rowSums", ",", "colSums"}], "]"}], "/", 
        RowBox[{"N", "[", "n", "]"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Basic", " ", "check", " ", "for", " ", "zero", " ", "expected", " ", 
        "frequencies"}], "*)"}], 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Min", "[", "expectedNumTable", "]"}], "<=", "0"}], ",", 
        RowBox[{
         RowBox[{
         "Print", "[", 
          "\"\<Error: Expected frequency table contains zero or non-positive \
values. Test cannot proceed reliably.\>\"", "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"Return", "[", "$Failed", "]"}], ";"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "3.", " ", "Calculate", " ", "Degrees", " ", "of", " ", "Freedom"}], 
       "*)"}], 
      RowBox[{"df", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"r", "-", "1"}], ")"}], "*", 
        RowBox[{"(", 
         RowBox[{"c", "-", "1"}], ")"}]}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"df", "<=", "0"}], ",", 
        RowBox[{
         RowBox[{
         "Print", "[", 
          "\"\<Error: Degrees of freedom is zero or negative (need >1 row and \
>1 column).\>\"", "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"Return", "[", "$Failed", "]"}], ";"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"4.", " ", "Calculate", " ", "Chi"}], "-", 
        RowBox[{"Squared", " ", "Statistic"}]}], "*)"}], 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"X", "^", "2"}], "=", 
        RowBox[{"Sum", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"Oij", "-", "Eij"}], ")"}], "^", "2"}], "/", "Eij"}], 
         "]"}]}], "*)"}], 
      RowBox[{"chiSquareStat", "=", 
       RowBox[{"Total", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Power", "[", 
           RowBox[{
            RowBox[{"observedTable", "-", "expectedNumTable"}], ",", "2"}], 
           "]"}], "/", "expectedNumTable"}], ",", "2"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"NumericQ", "[", "chiSquareStat", "]"}]}], ",", 
        RowBox[{
         RowBox[{
         "Print", "[", "\"\<Error calculating Chi-Squared statistic.\>\"", 
          "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"Return", "[", "$Failed", "]"}], ";"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"5.", " ", "Calculate", " ", "P"}], "-", "value"}], "*)"}], 
      RowBox[{"pValue", "=", 
       RowBox[{"SurvivalFunction", "[", 
        RowBox[{
         RowBox[{"ChiSquareDistribution", "[", "df", "]"}], ",", 
         "chiSquareStat"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"5", 
        RowBox[{"b", ".", "Calculate"}], " ", "Critical", " ", "Value"}], 
       "*)"}], 
      RowBox[{"criticalValue", "=", 
       RowBox[{"InverseCDF", "[", 
        RowBox[{
         RowBox[{"ChiSquareDistribution", "[", "df", "]"}], ",", 
         RowBox[{"1", "-", "alpha"}]}], "]"}]}], ";", 
      RowBox[{"(*", 
       RowBox[{
       "Using", " ", "Quantile", " ", "is", " ", "more", " ", "common"}], 
       "*)"}], 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"criticalValue", "=", 
         RowBox[{"Quantile", "[", 
          RowBox[{
           RowBox[{"ChiSquareDistribution", "[", "df", "]"}], ",", 
           RowBox[{"1", "-", "alpha"}]}], "]"}]}], ";"}], "*)"}], 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"Alternative", "/", "preferred"}], " ", "way"}], "*)"}], 
      RowBox[{"(*", 
       RowBox[{"6.", " ", "Minimal", " ", "Output"}], "*)"}], 
      RowBox[{
      "Print", "[", "\"\<--- Chi-Squared Independence Test ---\>\"", "]"}], 
      ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "Print", " ", "the", " ", "OBSERVED", " ", "table", " ", "WITH", " ", 
        "MARGINS"}], "*)"}], 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Observed Table (with Margins): \>\"", ",", 
        RowBox[{"MatrixForm", "[", "observedTableWithMargins", "]"}]}], "]"}],
       ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Expected Table (under H0): \>\"", ",", 
        RowBox[{"MatrixForm", "[", 
         RowBox[{"N", "[", 
          RowBox[{"expectedNumTable", ",", "4"}], "]"}], "]"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Degrees of Freedom (df): \>\"", ",", "df"}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<Chi-Squared Statistic (X^2): \>\"", ",", 
        RowBox[{"N", "[", 
         RowBox[{"chiSquareStat", ",", "5"}], "]"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<P-value: \>\"", ",", 
        RowBox[{"scientificFormIfNeeded", "[", "pValue", "]"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{
       "\"\<Critical Value (alpha=\>\"", ",", "alpha", ",", "\"\<): \>\"", 
        ",", 
        RowBox[{"N", "[", 
         RowBox[{"criticalValue", ",", "5"}], "]"}]}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "7.", " ", "Simple", " ", "Conclusion", " ", "based", " ", "on", " ", 
        "fixed", " ", "alpha"}], "*)"}], 
      RowBox[{"Print", "[", 
       RowBox[{
       "\"\<--- Conclusion (alpha = \>\"", ",", "alpha", ",", 
        "\"\<) ---\>\""}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"pValue", "<", "alpha"}], ",", 
        RowBox[{"Print", "[", 
         RowBox[{
         "\"\<P-value < \>\"", ",", "alpha", ",", 
          "\"\<. Reject H0: Variables appear dependent.\>\""}], "]"}], ",", 
        RowBox[{"Print", "[", 
         RowBox[{
         "\"\<P-value >= \>\"", ",", "alpha", ",", 
          "\"\<. Fail to reject H0: No significant evidence of \
dependence.\>\""}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"Optional", ":", 
        RowBox[{
        "Return", " ", "a", " ", "list", " ", "of", " ", "key", " ", 
         "results"}]}], "*)"}], 
      RowBox[{"Return", "[", 
       RowBox[{"{", 
        RowBox[{"df", ",", "chiSquareStat", ",", "pValue"}], "}"}], "]"}], 
      ";"}]}], "]"}]}], "\n", "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Sample", " ", "Observed", " ", "Data"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"observedData", "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"1", ",", " ", "3", ",", " ", "24"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"12", ",", " ", "28", ",", " ", "76"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"12", ",", " ", "14", ",", " ", "30"}], "}"}]}], "}"}]}], 
   ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Run", " ", "the", " ", "simplified", " ", "test"}], 
   "*)"}]}], "\n", 
 RowBox[{
  RowBox[{"resultsList", "=", 
   RowBox[{"SimpleChisquareIndependenceTest", "[", "observedData", "]"}]}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"If", " ", "the", " ", "test", " ", 
     RowBox[{"didn", "'"}], "t", " ", "fail"}], ",", 
    RowBox[{"resultsList", " ", "contains", " ", 
     RowBox[{"{", 
      RowBox[{"df", ",", "chiSquareStat", ",", "pValue"}], "}"}]}]}], 
   "*)"}]}], "\n", 
 RowBox[{"If", "[", 
  RowBox[{
   RowBox[{"ValueQ", "[", "resultsList", "]"}], ",", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<\\nReturned list: \>\"", ",", "resultsList"}], "]"}]}], 
  "]"}]}], "Input",
 CellChangeTimes->{{3.9541160744378204`*^9, 3.9541160744378204`*^9}, {
  3.954217948312432*^9, 3.9542179690693703`*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"22523973-9eac-a447-80ba-45acb32c3fca"],

