Sxy =Total[XY] -n*Mean[X]*Mean[Y];
b1 = Sxy/Sxx ;
b0 = Mean[Y]-b1*Mean[X];
SSE = Syy-b1*Sxy;
SST=Syy;
SSR=SST-SSE;
groupedData=GatherBy[Transpose[{X,Y}],First];

(*\:8ba1\:7b97 SSEpe*)
SSEpe=Total[Table[With[{group=groupedData[[i]]},With[{yi=group[[All,2]]},\
Total[yi^2]-(Total[yi]^2)/Length[yi]]],{i,Length[groupedData]}]];
SSElf=SSE-SSEpe;
R2 = Sxy^2 /(Sxx*Syy);
S =Sqrt[ SSE/(n-2)];
Print[\"n:\",n]
Print[\"X:\",Total[X]]
Print[\"Y:\",Total[Y]]
Print[\"X2:\",Total[X2]]
Print[\"Y2:\",Total[Y2]]
Print[\"XY:\",Total[XY]]
Print[\"SXY:\",Sxy]
Print[\"SXX:\",Sxx]
Print[\"SYY(SST):\",Syy]
Print[\"Y=\",b1,\"X+\",b0]
Print[\"SSE:\",SSE]
Print[\"SSR:\",SSR]
Print[\"SST:\",SST]
Print[\"SSEpe:\",SSEpe]
Print[\"SSElf:\",SSElf]
Print[\"S\:ff1a\",S]
Print[\"R2:\",R2]
